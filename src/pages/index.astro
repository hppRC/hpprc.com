---
import Base from '../layouts/Base.astro';

// hpprc.com is a single first-view page. Everything else lives at hpprc.dev.
const links = [
  { label: 'GitHub', href: 'https://github.com/hppRC' },
  { label: 'Scholar', href: 'https://scholar.google.com/citations?user=3xeQ7VYAAAAJ' },
  { label: 'Hugging Face', href: 'https://huggingface.co/hpprc' },
  { label: 'X', href: 'https://x.com/hayato_tkgs' },
  { label: 'hpprc.dev ↗', href: 'https://hpprc.dev' },
];
---

<Base>
  <main class="hero">
    <div class="hero-inner">
      <h1 class="hero-name">Hayato Tsukagoshi</h1>
      <p class="hero-role reveal">
        ML Engineer, Kotoba Technologies<span class="sep">/</span>PhD, Nagoya University
      </p>
      <p class="hero-summary reveal">
        Sentence embeddings and representation learning — now turning to speech.
      </p>
      <nav class="hero-links reveal" aria-label="Links">
        {links.map((l) => <a class="link" href={l.href} rel="me noopener" target="_blank">{l.label}</a>)}
        <!-- TODO confirm public email -->
        <button class="link copied" id="email" type="button"
          data-user="research.tsukagoshi.hayato" data-domain="gmail.com" aria-label="Reveal email">Email</button>
      </nav>
      <p class="hero-cap reveal">latent flow · advection — diffusion</p>
    </div>
  </main>
</Base>
