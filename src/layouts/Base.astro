---
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Hayato Tsukagoshi',
  description = 'Hayato Tsukagoshi — ML researcher working on sentence embeddings, text representation learning, and speech AI at Kotoba Technologies.',
} = Astro.props;

const site = 'https://hpprc.com';
const canonical = new URL(Astro.url.pathname, site).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="theme-color" content="#0a0b0d" />
    <meta name="color-scheme" content="dark" />

    <!-- Open Graph / Twitter -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={`${site}/og.jpg`} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${site}/og.jpg`} />

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    <!-- preload only the critical (Sans) face; Mono loads post-paint -->
    <link rel="preload" href="/fonts/geist-sans.woff2" as="font" type="font/woff2" crossorigin />

    <!-- progressive enhancement flag: reveals only hide when JS is present -->
    <script is:inline>document.documentElement.classList.add('js');</script>
  </head>
  <body>
    <canvas id="fluid" aria-hidden="true"></canvas>
    <slot />
    <script>import '../scripts/boot.ts';</script>
  </body>
</html>
